{
  "version": 2,
  "installCommand": "npm --prefix frontend ci",
  "buildCommand": "npm --prefix frontend run build && node -e \"const fs=require('node:fs');fs.mkdirSync('.vercel',{recursive:true});fs.rmSync('.vercel/output',{recursive:true,force:true});fs.cpSync('frontend/.vercel/output','.vercel/output',{recursive:true});\"",
  "framework": "vite"
}
